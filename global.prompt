# Global Prompt
[component: global]
[context: all-components]

@governance
- tone: "professional and friendly"
- language: "en-US"
- restricted-terms: ["click here", "free"]
- accessibility-check: "always validate WCAG 2.1"

@style-constraints
- css-framework: "tailwindcss"
- color-scheme: "brand-consistent"
- responsive-design: "mobile-first"

@code-quality
- use-typescript: true
- eslint-config: "strict"
- test-coverage: "minimum 80%"
